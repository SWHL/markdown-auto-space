{
  "publisher": "SWHL",
  "name": "markdown-auto-space",
  "displayName": "Markdown Auto Space",
  "version": "0.0.5",
  "private": true,
  "packageManager": "pnpm@9.14.1",
  "description": "Auto add space between Chinese and English in Markdown when you save file",
  "author": "SWHL<liekkaskono@163.com>",
  "license": "MIT",
  "homepage": "https://github.com/SWHL",
  "repository": {
    "type": "git",
    "url": "https://github.com/SWHL/markdown-auto-space.git"
  },
  "bugs": {
    "url": "https://github.com/SWHL/markdown-auto-space.git/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "browser": "./dist/web/extension.js",
  "icon": "res/icon.jpg",
  "engines": {
    "vscode": "^1.69.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.markdownAutoSpace",
        "title": "Markdown Auto Space: 对当前文档执行中英文加空格"
      },
      {
        "command": "extension.markdownAutoSpaceFormatSelection",
        "title": "Markdown Auto Space: 仅格式化选中行/选区"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "extension.markdownAutoSpace",
          "when": "editorLangId == markdown"
        },
        {
          "command": "extension.markdownAutoSpaceFormatSelection",
          "when": "editorLangId == markdown"
        }
      ],
      "editor/title": [
        {
          "command": "extension.markdownAutoSpace",
          "when": "editorLangId == markdown",
          "group": "1_modification"
        },
        {
          "command": "extension.markdownAutoSpaceFormatSelection",
          "when": "editorLangId == markdown",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "extension.markdownAutoSpace",
          "when": "editorLangId == markdown",
          "group": "1_modification"
        },
        {
          "command": "extension.markdownAutoSpaceFormatSelection",
          "when": "editorLangId == markdown",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Auto Space configuration",
      "properties": {
        "markdownAutoSpace.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show diagnostics (squiggles) where space rules are violated (e.g. MAS001: 中英文之间应有空格)"
        },
        "markdownAutoSpace.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Apply space rules when you manually save (e.g. Ctrl+S). Does not run on auto-save, so diagnostics (squiggles) stay until you save."
        },
        "markdownAutoSpace.formatOnDocument": {
          "type": "boolean",
          "default": false,
          "description": "Execute add space on Format Document command"
        },
        "markdownAutoSpace.spaceType": {
          "type": "string",
          "default": "all",
          "enum": [
            "all",
            "comment"
          ],
          "description": "Markdown Auto Space's type"
        },
        "markdownAutoSpace.rules": {
          "type": "object",
          "description": "Enable or disable each space rule by code (MAS001–MAS006). All default to true. See docs/RULES.md.",
          "properties": {
            "MAS001": {
              "type": "boolean",
              "default": true,
              "description": "中英文/数字之间应有空格"
            },
            "MAS002": {
              "type": "boolean",
              "default": true,
              "description": "中文与行内代码（反引号）之间应有空格"
            },
            "MAS003": {
              "type": "boolean",
              "default": true,
              "description": "中文与链接/URL 之间应有空格"
            },
            "MAS004": {
              "type": "boolean",
              "default": true,
              "description": "英文/数字间的顿号应改为逗号+空格"
            },
            "MAS005": {
              "type": "boolean",
              "default": true,
              "description": "斜杠与中文之间应有空格"
            },
            "MAS006": {
              "type": "boolean",
              "default": true,
              "description": "超链接 [] 内中英文混排时英文左右应有空格"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --external vscode",
    "build:web": "node scripts/build-web.mjs",
    "dev": "nr build --watch",
    "lint": "eslint . --fix",
    "vscode:prepublish": "nr build && nr build:web",
    "publish": "vsce publish --no-dependencies",
    "pack": "vsce package --no-dependencies",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && nr publish"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    },
    "overrides": {
      "jwa": ">=1.4.2"
    },
    "patchedDependencies": {
      "buffer-equal-constant-time@1.0.1": "patches/buffer-equal-constant-time@1.0.1.patch"
    }
  },
  "devDependencies": {
    "@antfu/ni": "^0.23.1",
    "@types/node": "^22.9.1",
    "@types/vscode": "^1.69.0",
    "@vscode/vsce": "^3.2.1",
    "bumpp": "^9.8.1",
    "esbuild": "^0.24.0",
    "eslint": "9.14.0",
    "pnpm": "^9.14.1",
    "rimraf": "^6.0.1",
    "talljack-eslint-config": "^0.2.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
